# Vercel AI Gateway — used for BOTH the image model and the judge model.
# Get one at https://vercel.com/dashboard (AI Gateway) or use a raw provider key.
AI_GATEWAY_API_KEY=

# Optional model overrides (defaults shown). Any provider/model the gateway supports.
# SPRITE_IMAGE_MODEL=openai/gpt-image-1
# JUDGE_MODEL=openai/gpt-4o-mini

# Sprite mode: "single" (static image, default) or "sheet" (4x4 CSS-animated
# spritesheet). The 4x4 sheet now generates reliably; uncomment to enable.
# SPRITE_MODE=sheet

# Convex — populated by `npx convex dev` on first run.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
